library(tidyverse)
library(jsonlite)
song_data <- fromJSON("https://stat.auckland.ac.nz/~fergusson/stats220_S124/data/lab4A.json")
summarised_data <- song_data %>%
  mutate(song_speed = ifelse(tempo > 120, 'fast', 'slow')) %>%

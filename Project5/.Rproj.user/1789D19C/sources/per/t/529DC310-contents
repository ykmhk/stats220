get_similarity <- function(phrase1, phrase2){
  
  words1 <- phrase1 %>% str_squish() %>% str_to_lower()%>%str_remove_all("[[:punct:]]") %>% str_split(" ") %>% unlist()
  words2 <- phrase2 %>% str_squish() %>% str_to_lower()%>%str_remove_all("[[:punct:]]") %>% str_split(" ") %>% unlist()
  
  num_same <- intersect(words1, words2) %>% length()
  num_total <- union(words1, words2) %>% length()
  
  round(num_same / num_total,1) # remember last thing created is returned by default, or use return()
}


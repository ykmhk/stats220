# uses the packages jsonlite and glue 
google_translate <- function(fromText, fromLanguage, toLanguage){
  fromText <- paste(fromText, collapse="|")
  url <- URLencode(glue("https://script.google.com/macros/s/AKfycbx3Bl6TUgxuG3YlqwEuWdADn9TeB05TpP0mzPRYzT1GKmBTZVk/exec?q={fromText}&source={fromLanguage}&target={toLanguage}"))
  fromJSON(url)
}

lyrics <- "Now, this is a story all about how my life got flipped-turned upside down"

# note how I am also mutating a column for the language used
data_m <- google_translate(fromText = lyrics, 
                           fromLanguage = "EN", 
                           toLanguage = "MI") %>%
  mutate(same = ifelse(original_phrase == reverse_phrase,
                       "yes",
                       "no"),
         language = "Te Reo")

data_j <- google_translate(fromText = lyrics, 
                           fromLanguage = "EN", 
                           toLanguage = "JA") %>%
  mutate(same = ifelse(original_phrase == reverse_phrase,
                       "yes",
                       "no"),
         language = "Japanese")

bind_rows(data_m, data_j)



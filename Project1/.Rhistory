img_height <- info$height
# split the image into top and bottom halves
top_half <- meme %>%
image_crop(geometry = geometry_area(width = img_width, height = img_height/2, x_off = 0, y_off = 0))
bottom_half <- meme %>%
image_crop(geometry = geometry_area(width = img_width, height = img_height/2, x_off = 0, y_off = img_height/2))
# optionally add text to each half
top_half <- top_half %>%
image_annotate(text = "Top Half!", color = "white", size = 50, gravity = "north")
bottom_half <- bottom_half %>%
image_annotate(text = "Bottom Half!", color = "white", size = 50, gravity = "south")
# create frames: frame 1 = top, frame 2 = bottom, frame 3 = top + bottom together, frame 4 = whole meme again
frame1 <- top_half
frame2 <- bottom_half
frame3 <- c(top_half, bottom_half) %>%
image_append(stack = TRUE) # stack vertically
frame4 <- meme # full image
# combine frames
frames <- c(frame1, frame2, frame3, frame4)
# animate
animation <- image_animate(frames, fps = 1) # 1 frame per second
# display animation
animation
